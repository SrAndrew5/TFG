# ═════════════════════════════════════════════════════════════════════════════
# Frontend — Variables de entorno
# ═════════════════════════════════════════════════════════════════════════════
# Solo las variables prefijadas con VITE_ se exponen al cliente.
# Las flags built-in import.meta.env.DEV / PROD / MODE las gestiona Vite solo.
# ═════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────
# API (obligatorio en producción)
# ─────────────────────────────────────────

# URL base del backend con el prefijo /api incluido.
# En desarrollo se omite: el proxy de vite.config.js redirige /api → :3001.
# En producción debe apuntar al dominio real del backend.
# Ejemplos:
#   Dev (déjalo vacío):  VITE_API_URL=
#   Prod misma máquina:  VITE_API_URL=/api
#   Prod subdominio:     VITE_API_URL=https://api.tudominio.com/api
VITE_API_URL=http://localhost:3001/api

# ─────────────────────────────────────────
# Branding (opcional, preparado para uso futuro)
# ─────────────────────────────────────────

# Nombre visible de la aplicación. Usado en title y emails desde frontend.
# VITE_APP_NAME=ReservasPro

# Email de soporte mostrado en pantallas de error / pendientes.
# VITE_SUPPORT_EMAIL=soporte@tudominio.com
