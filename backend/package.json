{
  "name": "reservas-backend",
  "version": "1.0.0",
  "description": "API REST — Sistema de Reservas Multiplataforma",
  "main": "src/index.js",
  "scripts": {
    "dev": "npx nodemon src/index.js",
    "start": "node src/index.js",
